# Copy this file to .env.local and fill in your SMTP credentials
# Never commit .env.local to version control

# ── SMTP Configuration ────────────────────────────────────────────
# For Gmail: use smtp.gmail.com with an App Password (not your account password)
# Generate an App Password at: https://myaccount.google.com/apppasswords
#
# For other providers (SendGrid, Mailgun, etc.) update host/port accordingly.

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your_app_password_here

# ── Lead notification recipient ───────────────────────────────────
# All quote form submissions are sent to this address
SMTP_TO=info@carexpresstransport.com
